# ════════════════════════════════════════════════════════════════
# Atelier Blanc — 環境變數完整清單
# 複製此檔為 .env.local（本地開發）或填入 Vercel Dashboard（正式部署）
# ════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────
# 來源：https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase 直連 (Server-side DB queries via postgres package)
# 來源：https://supabase.com/dashboard/project/_/settings/database → Connection string (Transaction mode)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# ── 信用卡本地金流（TapPay）──────────────────────────────────────
# 來源：https://developers.tappay.tw/dashboard
# 正式上線前，請將 /api/checkout/fiat 中的 mockFiatGateway() 替換為 TapPay Pay by Prime API
TAPPAY_PARTNER_KEY=partner_xxxxxxxxxxxxxxxxxxxxxxx
TAPPAY_MERCHANT_ID=your_merchant_id
# 或綠界 ECPay：
# ECPAY_MERCHANT_ID=your_merchant_id
# ECPAY_HASH_KEY=your_hash_key
# ECPAY_HASH_IV=your_hash_iv

# ── Stripe（保留，目前已切換至本地金流）──────────────────────────
# 如需重新啟用 Stripe，填入此處
# STRIPE_SECRET_KEY=sk_live_xxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ── Web3 / WalletConnect ──────────────────────────────────────────
# 來源：https://cloud.walletconnect.com（免費，必填否則 WalletConnect 不可用）
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# 平台收款錢包（接收 USDC 的 EVM 地址）
# 請替換為您的真實多簽錢包地址（建議使用 Gnosis Safe）
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=0xYourPlatformWalletAddress

# ── Google Analytics 4 ───────────────────────────────────────────
# 來源：https://analytics.google.com → 管理 → 資料串流 → 評估 ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── 站台設定 ──────────────────────────────────────────────────────
# 正式網域（用於 OG 圖片絕對路徑、metadataBase）
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ── 選填：Email 通知（訂單成立後寄信給藝術家）────────────────────
# 使用 Resend / SendGrid 等 transactional email 服務
# RESEND_API_KEY=re_xxxxxxxxxx
# NOTIFICATION_EMAIL=notifications@your-domain.com
